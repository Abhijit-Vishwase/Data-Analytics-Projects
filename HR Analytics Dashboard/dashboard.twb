            </column>
            <column caption='fullname' datatype='string' name='[Calculation_1068506628390930]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[First Name]+&apos; &apos;+[Last Name]' />
            </column>
            <column caption='length of hired' datatype='integer' name='[Calculation_1068506633687059]' role='measure' type='quantitative'>
