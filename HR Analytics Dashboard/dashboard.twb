            <column caption='location' datatype='string' name='[Calculation_1068506569515013]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [State]&#13;&#10;  WHEN &quot;New York&quot; THEN &quot;HQ&quot;&#13;&#10;  ELSE &quot;Branch&quot;&#13;&#10;END' />
            </column>
            <column caption='Age' datatype='integer' name='[Calculation_1068506574286856]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEDIFF(&apos;year&apos;,[Birthdate],TODAY())' />
            </column>
            <column caption='Status' datatype='string' name='[Calculation_1068506601574410]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF  ISNULL([Termdate]) THEN &quot;Hired&quot;&#13;&#10;ELSE &quot;Terminated&quot;&#13;&#10;END' />
            </column>
            <column caption='AVG(-1.0)' datatype='real' name='[Calculation_1068506628005905]' role='measure' type='quantitative' user:unnamed='Details'>
