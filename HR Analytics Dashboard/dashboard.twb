      <aliases enabled='yes' />
      <column caption='% total hired' datatype='real' default-format='p0.00%' name='[Calculation1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1068506563624960] / TOTAL([Calculation_1068506563624960])'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Total hired employee' datatype='integer' name='[Calculation_1068506563624960]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Employee_ID])' />
      </column>
      <column caption='Total terminited employee' datatype='integer' name='[Calculation_1068506563792897]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT( IF  NOT ISNULL([Termdate]) THEN [Employee_ID] END)' />
      </column>
      <column caption='Total Active employee' datatype='integer' name='[Calculation_1068506564739074]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT( IF ISNULL([Termdate]) THEN [Employee_ID]END)' />
      </column>
      <column caption='location' datatype='string' name='[Calculation_1068506569515013]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [State]&#13;&#10;  WHEN &quot;New York&quot; THEN &quot;HQ&quot;&#13;&#10;  ELSE &quot;Branch&quot;&#13;&#10;END' />
      </column>
      <column caption='Age' datatype='integer' name='[Calculation_1068506574286856]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;year&apos;,[Birthdate],TODAY())' />
      </column>
      <column caption='Age group' datatype='string' name='[Calculation_1068506574651401]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF  [Calculation_1068506574286856] &lt; 25 THEN &quot;&gt;25&quot;&#13;&#10;ELSEIF [Calculation_1068506574286856] &gt;=25 AND  [Calculation_1068506574286856] &lt;35 THEN &quot;25-34&quot;&#13;&#10;ELSEIF [Calculation_1068506574286856] &gt;=35 AND  [Calculation_1068506574286856] &lt;45 THEN &quot;35-44&quot;&#13;&#10;ELSEIF [Calculation_1068506574286856] &gt;=45 AND  [Calculation_1068506574286856] &lt;55 THEN &quot;45-54&quot;&#13;&#10;ELSEIF [Calculation_1068506574286856] &gt;= 55 THEN &quot;55+&quot;&#13;&#10;END' />
      </column>
      <column caption='Status' datatype='string' name='[Calculation_1068506601574410]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF  ISNULL([Termdate]) THEN &quot;Hired&quot;&#13;&#10;ELSE &quot;Terminated&quot;&#13;&#10;END' />
      </column>
      <column caption='highlight max' datatype='boolean' name='[Calculation_1068506604814347]' role='measure' type='nominal'>
        <calculation class='tableau' formula='WINDOW_MAX([Calculation_1068506563624960]) = [Calculation_1068506563624960]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='fullname' datatype='string' name='[Calculation_1068506628390930]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[First Name]+&apos; &apos;+[Last Name]' />
      </column>
      <column caption='length of hired' datatype='integer' name='[Calculation_1068506633687059]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ISNULL([Termdate]) THEN DATEDIFF(&apos;year&apos;,[Hiredate],TODAY())&#13;&#10;ELSE DATEDIFF(&apos;year&apos;,[Hiredate],[Termdate])&#13;&#10;END' />
      </column>
      <column datatype='string' name='[City]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
      <column datatype='string' name='[Education Level]' role='dimension' type='nominal'>
