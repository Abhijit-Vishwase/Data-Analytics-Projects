  <worksheets>
    <worksheet name='Age distribution'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontsize='16'>Age Group Distribution</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='appointments+' name='federated.011dt4h0evi0os1e6tuvp1ckkt67' />
          </datasources>
          <datasource-dependencies datasource='federated.011dt4h0evi0os1e6tuvp1ckkt67'>
            <column caption='Age' datatype='integer' name='[Calculation_0705614472577025]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='DATEDIFF(&apos;year&apos;,[date_of_birth],TODAY())' />
            </column>
            <column caption='Age Group' datatype='string' name='[Calculation_0705614474141699]' role='dimension' type='nominal'>
